# Copy to .env.local and fill with values from Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Prefer publishable key (Supabase UI / new dashboard). Legacy JWT anon still works:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Optional app branding (if used elsewhere)
# NEXT_PUBLIC_OFICINA_NOMBRE=
# NEXT_PUBLIC_OFICINA_DIRECCION=
# NEXT_PUBLIC_OFICINA_TELEFONO=
